{
  "name": "dublin-city-dashboard",
  "version": "1.0.0",
  "description": "Dublin Sustainable City Management Dashboard — desktop client with offline support",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron --no-sandbox .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "postinstall": "electron-rebuild",
    "rebuild": "@electron/rebuild",
    "test": "jest"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "electron-log": "^5.1.1",
    "leaflet.offline": "^2.2.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "@electron/rebuild": "^3.6.0",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "ie.tcd.ase.dublin-dashboard",
    "productName": "Dublin City Dashboard",
    "copyright": "Copyright © 2025 CS7CS3-ASE-Group9",
    "directories": {
      "output": "build",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "config/**/*",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,readme.md,readme}",
      "!node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/.bin"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*", "!**/__pycache__/**", "!**/*.pyc"]
      },
      {
        "from": "../frontend",
        "to": "frontend",
        "filter": ["**/*", "!**/__pycache__/**", "!**/*.pyc"]
      }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "assets/icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/src/__tests__/**/*.test.js"]
  }
}
